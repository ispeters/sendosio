#ifndef BEMAN_SENDOSIO_CONFIG_GENERATED_HPP
#define BEMAN_SENDOSIO_CONFIG_GENERATED_HPP

#cmakedefine01 BEMAN_SENDOSIO_USE_MODULES()

#cmakedefine01 BEMAN_SENDOSIO_FORCE_NO_CONTRACTS()

#if BEMAN_SENDOSIO_FORCE_NO_CONTRACTS()
    #define BEMAN_SENDOSIO_USE_CONTRACTS() 0
#else
    #if defined(__cpp_contracts) && __cpp_contracts >= 202502L
        #define BEMAN_SENDOSIO_USE_CONTRACTS() 1
    #else
        #define BEMAN_SENDOSIO_USE_CONTRACTS() 0
    #endif
#endif

#endif
